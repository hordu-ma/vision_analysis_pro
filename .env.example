# 环境变量配置示例

# API 配置
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:4173
LOG_FORMAT=json

# 模型配置
# 默认使用 stub 验证本地链路；切到 yolo/onnx 时使用下方 Stage A crack-only 路径。
INFERENCE_ENGINE=stub
YOLO_MODEL_PATH=runs/stage_a_crack/baseline_v0_1/weights/best.pt
ONNX_MODEL_PATH=models/stage_a_crack/best.onnx
MODEL_PATH=runs/stage_a_crack/baseline_v0_1/weights/best.pt
CONFIDENCE_THRESHOLD=0.5
IOU_THRESHOLD=0.5

# 旧版边缘设备配置（Settings 使用）
EDGE_DEVICE_ID=edge-01
EDGE_UPLOAD_INTERVAL=60
EDGE_VIDEO_SOURCE=0

# Edge Agent 配置
EDGE_AGENT_DEVICE_ID=edge-agent-001
EDGE_AGENT_SOURCE_TYPE=folder
EDGE_AGENT_SOURCE_PATH=data/images/test
EDGE_AGENT_INFERENCE_ENGINE=onnx
EDGE_AGENT_INFERENCE_MODEL_PATH=models/stage_a_crack/best.onnx
EDGE_AGENT_REPORTER_URL=http://localhost:8000/api/v1/report
EDGE_AGENT_REPORTER_API_KEY=
EDGE_AGENT_CACHE_DB_PATH=cache/edge_agent.db

# 云端配置
CLOUD_API_URL=http://localhost:8000
CLOUD_API_KEY=your-api-key-here

# Compose/统一部署配置
WEB_PORT=4173
# 使用 INFERENCE_ENGINE=onnx 时改为 true，以便 API 镜像安装 ONNX Runtime。
COMPOSE_INSTALL_ONNX=false
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# 数据库配置（预留）
# DATABASE_URL=postgresql://user:pass@localhost/vision_db

# 对象存储配置（预留）
# MINIO_ENDPOINT=localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
